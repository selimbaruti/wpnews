# =========================================
# WP News Importer — Configuration
# =========================================

# Timezone for determining "today"
TIMEZONE=Europe/Tirane

# WordPress REST API
WP_BASE_URL=https://chocolate-partridge-814635.hostingersite.com/
WP_USERNAME=selim
WP_APP_PASSWORD=3d*mj$!Bo1ITid*^PF

# Server port
PORT=3001

# Category cache TTL in minutes
CATEGORY_CACHE_TTL_MIN=10

# Concurrency limit for fetching child sitemaps / articles
CONCURRENCY_LIMIT=5

# ----- SOURCES -----
# Sources are configured in server/src/config/index.ts by default.
# Balkanweb and Top Channel are pre-configured.
#
# To override per-source sitemap URLs:
# SITEMAP_URL_BALKANWEB=https://www.balkanweb.com/wp-sitemap.xml
# SITEMAP_URL_TOPCHANNEL=https://top-channel.tv/sitemap.xml
#
# Or to add a custom single source (legacy):
# SITEMAP_URL=https://other-site.com/sitemap.xml
# ALLOWED_DOMAINS=other-site.com,www.other-site.com
# LAST_N_SITEMAPS=2
#
# Or full JSON override (advanced):
# SOURCES=[{"id":"mysite","name":"My Site","sitemapUrl":"...","allowedDomains":["..."],"lastNSitemaps":2,"reverseUrlOrder":true,"selectors":{}}]
